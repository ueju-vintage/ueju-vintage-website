<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UEJU Vintage</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
body{
margin:0;
font-family:Poppins;
background:linear-gradient(135deg,#fff0f5,#ffffff);
}

/* NAV */
nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 8%;
background:white;
box-shadow:0 10px 30px rgba(0,0,0,0.05);
}

.logo{
font-size:28px;
font-weight:700;
color:#ff4f9a;
}

/* HERO */
.hero{
display:flex;
align-items:center;
justify-content:space-between;
padding:60px 8%;
gap:40px;
}

.hero-text h1{
font-size:52px;
color:#ff4f9a;
}

.hero-text p{
color:#666;
margin-bottom:20px;
}

.btn{
background:#ff4f9a;
color:white;
padding:12px 25px;
border-radius:30px;
border:none;
cursor:pointer;
font-weight:600;
}

/* PRODUCTS */
.section-title{
text-align:center;
font-size:32px;
margin:40px 0;
color:#ff4f9a;
}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
padding:0 8%;
}

.card{
background:white;
border-radius:20px;
overflow:hidden;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
transition:0.3s;
}

.card:hover{
transform:translateY(-10px);
}

.card img{
width:100%;
height:320px;
object-fit:cover;
}

.card-body{
padding:15px;
text-align:center;
}

.price{
color:#ff4f9a;
font-size:20px;
font-weight:700;
}

/* CART */
.cart{
position:fixed;
right:20px;
top:100px;
width:250px;
background:white;
padding:15px;
border-radius:15px;
box-shadow:0 10px 30px rgba(0,0,0,0.1);
}

.cart h3{
color:#ff4f9a;
margin-top:0;
}

.item{
font-size:13px;
margin-bottom:5px;
}

.total{
font-weight:bold;
margin-top:10px;
}

.cart button{
width:100%;
margin-top:10px;
background:#25D366;
color:white;
border:none;
padding:10px;
border-radius:10px;
cursor:pointer;
}

/* FOOTER */
footer{
text-align:center;
padding:30px;
color:#888;
margin-top:40px;
}
</style>
</head>

<body>

<nav>
<div class="logo">UEJU Vintage 💖</div>
</nav>

<section class="hero">

<div class="hero-text">
<h1>L'élégance qui vous ressemble ✨</h1>
<p>Collection vintage exclusive au Maroc</p>
</div>

</section>

<h2 class="section-title">Nos Robes</h2>

<section class="products">

<div class="card">
<img src="images/robe-bleue.jpg">
<div class="card-body">
<h3>Robe Bleue Vintage</h3>
<p class="price">299 DH</p>
<p>S - M - L - XL</p>
<button class="btn" onclick="add('Robe Bleue',299)">Ajouter au panier</button>
</div>
</div>

<div class="card">
<img src="images/robe-rose.jpg">
<div class="card-body">
<h3>Robe Fleurie Rose</h3>
<p class="price">249 DH</p>
<p>S - M - L - XL</p>
<button class="btn" onclick="add('Robe Rose',249)">Ajouter au panier</button>
</div>
</div>

</section>

<!-- CART -->
<div class="cart">
<h3>🛒 Panier</h3>
<div id="items"></div>
<div class="total">Total: <span id="total">0</span> DH</div>
<button onclick="order()">Commander WhatsApp</button>
</div>

<footer>
© 2026 UEJU Vintage 💖
</footer>

<script>
let cart=[];

function add(name,price){
cart.push({name,price});
render();
}

function render(){
let box=document.getElementById("items");
let total=0;
box.innerHTML="";

cart.forEach(i=>{
total+=i.price;
box.innerHTML+=`<div class='item'>${i.name} - ${i.price} DH</div>`;
});

document.getElementById("total").innerText=total;
}

function order(){
let phone="212600000000"; // بدّلي رقمك هنا
let msg="Bonjour, je veux commander:%0A";

cart.forEach(i=>{
msg+=`- ${i.name} ${i.price} DH%0A`;
});

msg+=`Total: ${document.getElementById("total").innerText} DH`;

window.open("https://wa.me/"+phone+"?text="+encodeURIComponent(msg));
}
</script>

</body>
</html>